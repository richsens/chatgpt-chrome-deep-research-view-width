{
  "manifest_version": 3,
  "name": "ChatGPT Deep Research Width",
  "version": "0.1.0",
  "description": "Adjust ChatGPT Deep Research report width to 1.5x or 2x for better table readability.",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.web-sandbox.oaiusercontent.com/*"
  ],
  "action": {
    "default_title": "Deep Research Width",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://*.web-sandbox.oaiusercontent.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
